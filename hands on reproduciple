        "-o", output_file,
        "--from", "markdown",
        "--pdf-engine=xelatex",
        "-V", "geometry:margin=1in",
        "-V", "fontsize=11pt",
        "-V", "mainfont=Times New Roman",
        "-V", "monofont=Courier New",
        "-V", "linkcolor=blue",
        "-V", "toc",
        "--toc-depth=2"
    ]
    subprocess.run(cmd, check=True)

