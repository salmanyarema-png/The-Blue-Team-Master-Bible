name: Build Curriculum PDF

on:
  push:
    branches:
      - main
  pull_request:

jobs:
  build-pdf:
    runs-on: ubuntu-latest

    steps:
      # Checkout repository
      - name: Checkout code
        uses: actions/checkout@v3

      # Install Pandoc and LaTeX engine
      - name: Install Pandoc and LaTeX
        run: |
          sudo apt-get update
          sudo apt-get install -y pandoc texlive-xetex

      # Convert Markdown to PDF
      - name: Generate PDF
        run: |
          pandoc curriculum.md \
            -o curriculum.pdf \
            --from markdown \
            --pdf-engine=xelatex \
            -V geometry:margin=1in \
            -V fontsize=11pt \
            -V mainfont="Times New Roman" \
            -V monofont="Courier New" \
            -V linkcolor=blue \
            -V toc \
            --toc-depth=2

      # Upload PDF as workflow artifact
      - name: Upload PDF artifact
        uses: actions/upload-artifact@v3
        with:
          name: curriculum-pdf
          path: curriculum.pdf


