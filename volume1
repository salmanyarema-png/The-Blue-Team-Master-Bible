            <article id="ch2-4" class="mb-20 chapter-content">
                <div class="chapter-card rounded-2xl p-8 md:p-12">
                    <div class="flex items-center mb-6">
                        <span class="text-6xl font-bold text-slate-700 mr-4">07</span>
                        <div>
                            <h3 class="text-3xl font-bold serif text-white">OSI Layer 3: Network Layer</h3>
                            <p class="text-blue-400">IP Addressing, Routing, and Internet Architecture</p>
                        </div>
