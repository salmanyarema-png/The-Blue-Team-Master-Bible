                                <p class="text-slate-400 mt-2"># Check IPv6 configuration</p>
                                <p class="text-green-400">$ ip -6 addr show</p>
                                <p class="text-green-400">$ ip -6 route show</p>
                            </div>
                        </div>
                    </div>
                </div>
