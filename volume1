    <script>
        // Binary background animation
        const binaryBg = document.getElementById('binaryBg');
        let binaryText = '';
        for (let i = 0; i < 2000; i++) {
            binaryText += Math.random() > 0.5 ? '1' : '0';
            if (i % 100 === 0) binaryText += '\n';
        }
        binaryBg.textContent = binaryText;

        // Scroll indicator
        window.addEventListener('scroll', () => {
            const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
            const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            const scrolled = (winScroll / height) * 100;
            document.getElementById('scrollIndicator').style.width = scrolled + '%';
        });

        // GSAP Animations
        gsap.registerPlugin(ScrollTrigger);

        // Animate chapter cards on scroll
        gsap.utils.toArray('.chapter-content').forEach((chapter, i) => {
            gsap.from(chapter, {
                scrollTrigger: {
                    trigger: chapter,
                    start: 'top 80%',
                    toggleActions: 'play none none reverse'
                },
                opacity: 0,
                y: 50,
                duration: 0.8,
                ease: 'power2.out'
            });
        });

        // Table of contents active state
        const sections = document.querySelectorAll('article[id], section[id]');
        const tocLinks = document.querySelectorAll('.toc-link');

        window.addEventListener('scroll', () => {
            let current = '';
            sections.forEach(section => {
                const sectionTop = section.offsetTop;
                const sectionHeight = section.clientHeight;
                if (pageYOffset >= sectionTop - 200) {
                    current = section.getAttribute('id');
                }
            });

            tocLinks.forEach(link => {
                link.classList.remove('active');
                if (link.getAttribute('href') === '#' + current) {
                    link.classList.add('active');
                }
            });
        });

        // Smooth scroll for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });
    </script>
